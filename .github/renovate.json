{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "every weekday",
    "on saturday",
    "on sunday"
  ],
  "automergeType": "branch",
  "automerge": true,
  "automergeStrategy": "merge-commit",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/unbound\\.txt$"
      ],
      "matchStrings": [
        "unbound=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "NLnetLabs/unbound",
      "extractVersionTemplate": "^release-(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)$",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/openssl-buildenv\\.txt$"
      ],
      "matchStrings": [
        "OPENSSL_BUILDENV_VERSION=(?<currentValue>[0-9A-Za-z._-]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "node"
    },

    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/openssl-quic-buildenv\\.txt$"
      ],
      "matchStrings": [
        "OPENSSL_QUIC_BUILDENV_VERSION=(?<currentValue>[0-9A-Za-z._-]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "node"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "separateMinorPatch": false,
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "allowedVersions": "!/-quic$/",
      "labels": ["bump-openssl-subversion"]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "allowedVersions": "/-quic$/",
      "labels": ["bump-quic-subversion"]
    }
  ]
}
